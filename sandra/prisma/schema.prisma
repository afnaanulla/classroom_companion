generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TEACHER
  STUDENT
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  FEEDBACK_GIVEN
}

enum EscalationLevel {
  GENTLE
  MODERATE
  URGENT
  OVERDUE
}

model User {
  id                  String    @id @default(cuid())
  telegramId          String    @unique
  name                String
  role                UserRole
  inviteCode          String?   @unique
  inviteCodeExpiresAt DateTime?
  inviteCodeUses      Int       @default(0)
  teacherProfile      Teacher?
  studentProfile      Student?
  createdAt           DateTime  @default(now())
}

model Teacher {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  teacherStudents TeacherStudent[]
  assignments     Assignment[]
  feedbacks       Feedback[]
  createdAt       DateTime         @default(now())
}

model Student {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  teacherStudents TeacherStudent[]
  assignments     Assignment[]
  submissions     Submission[]
  progressUpdates ProgressUpdate[]
  reminders       Reminder[]
  createdAt       DateTime         @default(now())
}

model TeacherStudent {
  id        String   @id @default(cuid())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, studentId])
}

model Assignment {
  id              String           @id @default(cuid())
  title           String
  description     String
  deadline        DateTime
  status          AssignmentStatus @default(PENDING)
  teacherId       String
  teacher         Teacher          @relation(fields: [teacherId], references: [id])
  studentId       String
  student         Student          @relation(fields: [studentId], references: [id])
  submissions     Submission[]
  progressUpdates ProgressUpdate[]
  feedbacks       Feedback[]
  reminders       Reminder[]
  createdAt       DateTime         @default(now())

  @@index([teacherId])
  @@index([studentId])
  @@index([deadline])
  @@index([status])
}

model Submission {
  id           String     @id @default(cuid())
  textContent  String
  filePath     String?
  reviewed     Boolean    @default(false)
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  submittedAt  DateTime   @default(now())

  @@index([assignmentId])
  @@index([studentId])
}

model ProgressUpdate {
  id           String     @id @default(cuid())
  message      String
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  createdAt    DateTime   @default(now())
}

model Feedback {
  id           String     @id @default(cuid())
  message      String
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  teacherId    String
  teacher      Teacher    @relation(fields: [teacherId], references: [id])
  deliveredAt  DateTime?
  readAt       DateTime?
  createdAt    DateTime   @default(now())

  @@index([assignmentId])
}

model Reminder {
  id              String          @id @default(cuid())
  message         String
  scheduledFor    DateTime
  sentAt          DateTime?
  escalationLevel EscalationLevel @default(GENTLE)
  retryCount      Int             @default(0)
  assignmentId    String
  assignment      Assignment      @relation(fields: [assignmentId], references: [id])
  studentId       String
  student         Student         @relation(fields: [studentId], references: [id])
  createdAt       DateTime        @default(now())

  @@index([scheduledFor])
  @@index([sentAt])
}

model AgentLog {
  id         String   @id @default(cuid())
  agentType  String
  input      String
  output     String
  durationMs Int
  executedAt DateTime @default(now())

  @@index([agentType])
  @@index([executedAt])
}